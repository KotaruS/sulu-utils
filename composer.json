{
    "name": "kotaru/sulu-utils",
    "type": "sulu-utilities",
    "version": "1.0.1",
    "description": "Collection of utilities and improvements for Sulu 2 CMS",
    "keywords": [
        "sulu",
        "suluCms",
        "utilities"
    ],
    "homepage": "https://github.com/KotaruS/sulu-utils",
    "license": "MIT",
    "authors": [
        {
            "name": "Martin Soukup"
        }
    ],
    "require": {
        "php": "^8.2",
        "sulu/sulu": "2.6.24",
        "symfony/config": "^7.0",
        "symfony/dependency-injection": "^7.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/http-foundation": "^7.0",
        "symfony/http-kernel": "^7.0"
    },
    "require-dev": {
        "jangregor/phpstan-prophecy": "^2.0",
        "php-cs-fixer/shim": "^3.58",
        "phpspec/prophecy-phpunit": "^2.1",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpstan/phpstan-webmozart-assert": "^2.0",
        "phpunit/phpunit": "^11.5 || ^12.1",
        "rector/rector": "^2.0",
        "sulu/sulu-rector": "^2.0",
        "symfony/browser-kit": "^7.4",
        "symfony/css-selector": "^7.4",
        "symfony/debug-bundle": "^7.4",
        "symfony/error-handler": "^7.4",
        "symfony/phpunit-bridge": "^7.4",
        "symfony/web-profiler-bundle": "^7.4"
    },
    "scripts": {
        "php-cs-fixer": [
            "@php vendor/bin/php-cs-fixer fix"
        ],
        "phpstan": [
            "@php vendor/bin/phpstan analyse"
        ],
        "phpunit": "@php vendor/bin/phpunit --testdox",
        "bootstrap-test-environment": [
            "@php Tests/Application/bin/console doctrine:database:create --if-not-exists",
            "@php Tests/Application/bin/console doctrine:schema:update --force"
        ]
    },
    "autoload": {
        "psr-4": {
            "Kotaru\\SuluUtils\\": ""
        }
    },
    "config": {
        "sort-packages": true
    }
}
